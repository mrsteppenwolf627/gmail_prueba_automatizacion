# Google OAuth 2.0 credentials (from credentials.json or GCP Console)
GOOGLE_CLIENT_ID=your_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_PROJECT_ID=your-gcp-project-id

# Refresh token obtained from scripts/setup_oauth.py
GOOGLE_REFRESH_TOKEN=your_refresh_token_here

# Gmail account to watch and send replies from
GMAIL_USER_ID=aitor@aitoralmu.xyz

# Auto-reply message body
AUTO_REPLY_BODY=Te he recibido, te contesto en breves.
